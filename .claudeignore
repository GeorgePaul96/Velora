# .claudeignore — paths Claude Code should never read/scan.
# These carry no design signal and are pure token/scan cost. Most are also in .gitignore;
# this file states the intent explicitly and covers nested + non-git-ignored cases.

# Dependencies (150 MB root + nested copies in each app — the bulk of the repo)
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# Build outputs (regenerated by `vite build`; ~400 KB minified bundles each)
dist/
apps/*/dist/
**/dist-ssr/

# TypeScript incremental build cache
*.tsbuildinfo

# Lockfiles (huge, machine-generated, no architectural signal)
package-lock.json
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# Binary / media assets (not readable as text signal)
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.exe
*.bin
# SVGs here are inline-icon/logo assets, not source to reason about
*.svg

# Logs, caches, temp, OS noise
*.log
logs/
.cache/
.temp/
.branches/
.DS_Store
*.local

# Env / secrets — never read
.env
.env.*
.supabase/

# Editor
.vscode/
.idea/
